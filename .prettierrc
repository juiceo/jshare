{
	"printWidth": 120,
	"tabWidth": 4,
	"useTabs": true,
	"trailingComma": "all",
	"singleQuote": true,
	"importOrder": ["^react$", "", "<THIRD_PARTY_MODULES>", "", "^@/(.*)$", "", "^[./]"],
	"importOrderSeparation": false,
	"importOrderSortSpecifiers": true,
	"importOrderMergeDuplicateImports": true
}
